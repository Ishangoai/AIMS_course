# scripts/utils.py
from typing import Union
from PIL import Image, ImageOps, ImageEnhance
from PIL.Image import Image as PILImage


def grayscale(image: PILImage) -> PILImage:
    """Convertit l'image en niveaux de gris."""
    return ImageOps.grayscale(image)


def brightness(image: PILImage, brightness_factor: float) -> PILImage:
    """Applique l'ajustement de luminosité."""
    enhancer = ImageEnhance.Brightness(image)
    return enhancer.enhance(brightness_factor)


def contrast(image: PILImage, contrast_factor: float) -> PILImage:
    """Applique l'ajustement de contraste."""
    enhancer = ImageEnhance.Contrast(image)
    return enhancer.enhance(contrast_factor)


def rotate_image(image: PILImage, degree: Union[int, float]) -> PILImage:
    """Rotate the image; expand=True to fit the rotated result."""
    return image.rotate(degree, expand=True)


def apply_zoom(image: PILImage, zoom_factor: float) -> PILImage:
    """Zoom in/out l'image par un facteur."""
    if zoom_factor == 1.0:
        return image
    w, h = image.size
    new_w, new_h = int(w * zoom_factor), int(h * zoom_factor)
    return image.resize((new_w, new_h), resample=Image.LANCZOS)


def remove_white_background(image: PILImage, threshold: int) -> PILImage:
    """Rend le fond blanc (au-dessus du seuil) transparent."""
    img = image.convert("RGBA")
    pixels = list(img.getdata())

    new_data = []
    for item in pixels:
        if item[0] > threshold and item[1] > threshold and item[2] > threshold:
            new_data.append((255, 255, 255, 0))
        else:
            new_data.append(item)

    img.putdata(new_data)
    return img


def transform_image(
    image: PILImage,
    grayscale_or_not: str,
    brightness_factor: float,
    contrast_factor: float,
    degree: Union[int, float],
    threshold: int,
) -> PILImage:
    """Applique la suite de transformations sur l'image en respectant ton raisonnement."""
    if grayscale_or_not == "Grayscale":
        img = grayscale(image)
    else:
        img = image

    img = brightness(img, brightness_factor)
    img = contrast(img, contrast_factor)
    img = rotate_image(img, degree)
    img = remove_white_background(img, threshold)

    return img
